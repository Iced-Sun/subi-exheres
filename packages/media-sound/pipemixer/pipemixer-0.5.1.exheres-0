require github [ user=heather7283 tag=v${PV} ] meson

SUMMARY="TUI volume control app for pipewire"
LICENCES="GPL-3"
SLOT="0"
PLATFORMS="~amd64"
MYOPTIONS=""

DEPENDENCIES="
    build+run:
        dev-libs/inih
        media/pipewire
	sys-libs/ncurses
"

MESON_SRC_CONFIGURE_PARAMS=(
    -Dshell-completions=false
)
